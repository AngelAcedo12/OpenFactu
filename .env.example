# Puertos locales (pueden ser modificados por el instalador en caso de conflicto)
SERVER_PORT=3000
WEB_PORT=8080
DB_PORT=5432

# Base de datos (Postpuesta para el futuro, pero aquí estará)
DATABASE_URL=postgresql://openfactu:openfactu_pass@db:5432/openfactudb

# ── Monitoreo ──
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@openfactu.com
PGADMIN_PASSWORD=admin

GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001

PROMETHEUS_PORT=9090
LOKI_PORT=3100
CADVISOR_PORT=8081
NODE_EXPORTER_PORT=9100
PORTAINER_PORT=9000

# Container de PostgreSQL para pg_dump
OPENFACTU_PG_CONTAINER=db
