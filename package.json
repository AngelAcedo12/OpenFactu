{
  "name": "openfactu",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "docker compose up -d",
    "dev:server": "npm run dev --workspace=@openfactu/server",
    "dev:web": "npm run dev --workspace=@openfactu/web",
    "dev:web:https": "npm run dev:https --workspace=@openfactu/web",
    "dev:all": "docker compose stop server web && docker compose up -d db && concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:all:https": "docker compose stop server web && docker compose up -d db && concurrently \"npm run dev:server\" \"npm run dev:web:https\"",
    "install:all": "npm install",
    "cli": "npx ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"esModuleInterop\":true}' packages/cli/bin/openfactu.ts",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,md,css}\" \"packages/**/*.{ts,tsx,js,jsx,json,md,css}\" \"plugins/**/*.{ts,tsx,js,jsx,json,md,css}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,md,css}\" \"packages/**/*.{ts,tsx,js,jsx,json,md,css}\" \"plugins/**/*.{ts,tsx,js,jsx,json,md,css}\" \"*.{json,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "3.8.3"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@openfactu/pdf": "^0.1.0",
    "drizzle-orm": "^0.45.2"
  }
}
