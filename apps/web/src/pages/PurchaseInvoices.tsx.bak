import React, { useEffect, useState } from 'react';
import { Table, Card, Button, Input, Loader, useToast, Badge, FilterBar } from '@openfactu/ui';
import { useAuth } from '../context/AuthContext';
import { FileStack, Plus, Trash2, ArrowLeft, Save, ShoppingCart, ClipboardList, FileText, AlertCircle, Copy, PlusSquare } from 'lucide-react';
import { SearchableSelect } from '@openfactu/ui';
import { BatchSelectionModal } from '../components/BatchSelectionModal';
import { useDocument, useDataTable } from '@openfactu/common';

export const PurchaseInvoices: React.FC = () => {
  const { token, user } = useAuth();
  const toast = useToast();
  
  const [view, setView] = useState<'list' | 'create' | 'detail'>('list');
  const [invoices, setInvoices] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);

  const [selectedInvoice, setSelectedInvoice] = useState<any>(null);

  // Hook Central
  const { 
    state: { partnerId, seriesId, periodId, date, lines, isSubmitting, seriesError },
    setState: { setPartnerId, setSeriesId, setPeriodId, setDate, setLines },
    masters: { partners, items, series, periods, taxGroups },
    actions: { addLine, updateLine, submitDocument },
    computations: { subtotal, taxTotal, total }
  } = useDocument({ 
    token: token || '', 
    tenantId: user?.tenantId || '', 
    docType: 'PINV', 
    apiEndpoint: '/api/purchases/invoices' 
  });

  // Hook Filtros
  const { 
    filteredData, 
    searchTerm, setSearchTerm, 
    activeFilters, setFilter, clearFilters 
  } = useDataTable({ 
    data: invoices,
    searchColumns: ['docCode', 'baseCode', 'partnerName', 'total'] as any,
    filters: [
      { key: 'partnerId', type: 'select', label: 'Proveedor', options: partners.map(p => ({ label: p.name, value: p.id })) },
      { key: 'status', type: 'select', label: 'Estado', options: [
        { label: 'Asentado', value: 'O' },
        { label: 'Cancelado', value: 'X' }
      ]},
      { key: 'date', type: 'date', label: 'Fecha' }
    ]
  });

  const [batchEditingIdx, setBatchEditingIdx] = useState<number | null>(null);

  const fetchInvoices = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/purchases/invoices', {
        headers: { Authorization: `Bearer ${token}`, 'x-tenant-id': user?.tenantId || '' }
      });
      const data = await res.json();
      const mapped = (Array.isArray(data) ? data : []).map(inv => ({
        ...inv,
        docCode: `${inv.seriesPrefix}-${inv.periodCode}-${String(inv.docNum).padStart(6, '0')}`,
        baseCode: inv.baseDocNum ? `${inv.basePrefix}-${inv.periodCode}-${String(inv.baseDocNum).padStart(6, '0')}` : '',
        partnerName: partners.find(p => p.id === inv.partnerId)?.name || ''
      }));
      setInvoices(mapped);
    } catch {
      toast.error('Error al cargar facturas');
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    if (user?.tenantId) {
      fetchInvoices();

      // Auto-fill from Delivery Note (PDN) if copyFrom is in URL
      const urlParams = new URLSearchParams(window.location.search);
      const copyPdnId = urlParams.get('copyFrom');
      if (copyPdnId) {
        const sourceData = localStorage.getItem('copy_pdn_source');
        if (sourceData) {
          const pdn = JSON.parse(sourceData);
          setPartnerId(pdn.partnerId);
          setLines(pdn.lines.map((l:any) => ({
            itemId: l.itemId,
            quantity: l.quantity,
            price: l.price,
            baseType: 'PDN',
            baseId: pdn.id,
            baseLine: l.lineNum,
            batchDetails: l.batchDetails || [], 
            lineNum: l.lineNum
          })));
          setView('create');
          window.history.replaceState({}, '', '/purchases/invoices');
        }
      }
    }
  }, [user?.tenantId]);

  const handleViewDetail = async (id: string) => {
    setLoading(true);
    try {
      const res = await fetch(`/api/purchases/invoices/${id}`, {
        headers: { Authorization: `Bearer ${token}`, 'x-tenant-id': user?.tenantId || '' }
      });
      const data = await res.json();
      setSelectedInvoice(data);
      setView('detail');
    } catch {
      toast.error('Error al cargar detalle');
    } finally {
      setLoading(false);
    }
  };

  const handleCancel = async (id: string) => {
    if (!confirm('¿Seguro que deseas cancelar esta factura? Si venía de albaranes, estos se reabrirán.')) return;
    try {
      const res = await fetch(`/api/purchases/invoices/${id}`, {
        method: 'DELETE',
        headers: { Authorization: `Bearer ${token}`, 'x-tenant-id': user?.tenantId || '' }
      });
      if (!res.ok) throw new Error('Error al cancelar');
      toast.success('Factura cancelada exitosamente');
      fetchInvoices();
      setView('list');
    } catch (err: any) {
      toast.error(err.message);
    }
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();

    // Validation
    if (!partnerId) return toast.error('El Proveedor es obligatorio');
    if (!seriesId) return toast.error('La Serie de Numeración es obligatoria');
    if (!periodId) return toast.error('El Periodo Contable es obligatorio');
    if (!date) return toast.error('La Fecha del Documento es obligatoria');
    if (lines.length === 0) return toast.error('El documento debe tener al menos una línea');
    if (lines.some(l => !l.itemId)) return toast.error('Todas las líneas deben tener un artículo seleccionado');

    try {
      const data = await submitDocument();
      toast.success(`Factura creada exitosamente con número ${data.docNum}`);
      setView('list');
      fetchInvoices();
    } catch (err: any) {
      toast.error(err.message);
    }
  };

  const listColumns = [
    { header: 'No. Factura', cell: (c:any) => (
        <Badge variant="neutral" className="font-mono font-black text-[10px] tracking-widest px-2 py-1">
          {c.seriesPrefix}-{c.periodCode}-{String(c.docNum).padStart(6, '0')}
        </Badge>
    )},
    { header: 'Fecha', cell: (c:any) => new Date(c.date).toLocaleDateString() },
    { header: 'Proveedor', cell: (c:any) => partners.find(p => p.id === c.partnerId)?.name || '...' },
    { header: 'Doc. Origen', cell: (c:any) => c.baseDocNum ? (
        <Badge variant="info" className="font-mono font-black text-[10px] tracking-widest px-2 py-1 opacity-80">
          {c.basePrefix}-{c.periodCode}-{String(c.baseDocNum).padStart(6, '0')}
        </Badge>
    ) : <span className="text-slate-400">-</span> },
    { header: 'Total', cell: (c:any) => <span className="font-bold">{c.total} €</span> },
    { header: 'Estado', cell: (c:any) => (
       <>
         {c.status === 'O' && <Badge variant="success">Asentado</Badge>}
         {c.status === 'X' && <Badge variant="error" className="bg-rose-100 text-rose-700">Cancelado</Badge>}
       </>
    )},
    { header: '', cell: (c:any) => (
      <Button variant="secondary" size="sm" onClick={() => handleViewDetail(c.id)}>Ver Detalle</Button>
    )}
  ];

  if (view === 'create') {
     return (
       <div className="p-8 max-w-7xl mx-auto space-y-6">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-4">
              <button onClick={() => setView('list')} className="p-2 hover:bg-slate-200 rounded-lg transition"><ArrowLeft size={20} /></button>
              <h1 className="text-3xl font-black text-slate-900 tracking-tight">Nueva Factura de Compra</h1>
              {lines.some(l => l.baseType === 'PDN') && (
                <Badge variant="info" className="flex items-center gap-1.5 bg-blue-50 text-blue-700 border-blue-100">
                  <ShoppingCart size={12}/> Copiado de Albarán - Modo Solo Lectura
                </Badge>
              )}
            </div>
            <Button onClick={handleSubmit} disabled={isSubmitting || !!seriesError} className="flex items-center gap-2">
               {isSubmitting ? <Loader size="sm" /> : <Save size={18} />} Contabilizar Factura
             </Button>
           </div>

           {seriesError && (
             <div className="p-4 bg-rose-50 border border-rose-100 rounded-xl flex items-center gap-3 text-rose-700 animate-in slide-in-from-top-4 duration-300">
                <div className="w-10 h-10 bg-rose-100 rounded-full flex items-center justify-center text-rose-600">
                   <AlertCircle size={24} />
                </div>
                <div>
                   <p className="text-sm font-black uppercase leading-tight">Acceso Bloqueado</p>
                   <p className="text-xs font-medium opacity-80">{seriesError}. Por favor, configure una serie en Finanzas & Setup.</p>
                </div>
             </div>
           )}

          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            <Card className="p-6 md:col-span-2 space-y-6 shadow-lg border-t-4 border-t-amber-500">
               <div className="border-b pb-3 flex justify-between items-center">
                  <h3 className="font-bold text-slate-700 uppercase text-xs tracking-wider">Cabecera de Factura</h3>
                  <span className="text-[9px] font-bold text-rose-500 uppercase">* Campos obligatorios</span>
               </div>
               <div>
                  <label className="text-[10px] font-black text-slate-400 uppercase mb-1 block flex items-center gap-1">
                    Proveedor / Acreedor <span className="text-rose-500">*</span>
                  </label>
                  <select 
                    value={partnerId} 
                    onChange={e => setPartnerId(e.target.value)} 
                    className={`w-full h-10 border rounded-lg px-3 text-sm bg-white font-bold transition-all ${!partnerId ? 'border-rose-200 bg-rose-50/20' : 'border-slate-200'}`}
                  >
                    <option value="">Seleccionar Proveedor...</option>
                    {partners.map(p => <option key={p.id} value={p.id}>{p.name}</option>)}
                  </select>
               </div>
               <div>
                  <label className="text-[10px] font-black text-slate-400 uppercase mb-1 block flex items-center gap-1">
                    Fecha de Factura <span className="text-rose-500">*</span>
                  </label>
                  <Input 
                    type="date" 
                    value={date} 
                    onChange={e => setDate(e.target.value)} 
                    className={!date ? 'border-rose-200 bg-rose-50/20' : ''}
                  />
               </div>
            </Card>
            <Card className="p-6 space-y-4 bg-slate-50 relative overflow-hidden">
               <div className="absolute top-0 right-0 p-2 opacity-5">
                  <FileText size={80} />
               </div>
               <h4 className="text-[10px] font-black text-slate-400 uppercase">Numeración y Periodo</h4>
               <div className="space-y-4 relative z-10">
                  <div>
                     <label className="text-[9px] font-black text-slate-400 uppercase mb-1 block flex items-center gap-1">
                       Serie de Numeración <span className="text-rose-500">*</span>
                     </label>
                     <select 
                       value={seriesId} 
                       onChange={e => setSeriesId(e.target.value)} 
                       className={`w-full h-10 border rounded-lg px-3 text-sm bg-white font-bold transition-all ${!seriesId ? 'border-rose-200 bg-rose-50/20' : 'border-slate-200'}`}
                     >
                        <option value="">Serie...</option>
                        {series.map(s => <option key={s.id} value={s.id}>{s.name}</option>)}
                     </select>
                  </div>
                  
                  {seriesId && (
                    <div className="p-3 bg-white rounded-xl border border-blue-100 shadow-sm animate-in zoom-in-95 duration-200">
                       <p className="text-[9px] font-black text-blue-500 uppercase">Siguiente Número</p>
                       <p className="text-xl font-black text-slate-800 tracking-tighter">
                         {(() => {
                           const s = series.find(x => x.id === seriesId);
                           return s ? `${s.prefix}-${s.nextNumber}` : '---';
                         })()}
                       </p>
                    </div>
                  )}

                  <div>
                     <label className="text-[9px] font-black text-slate-400 uppercase mb-1 block flex items-center gap-1">
                       Periodo Contable <span className="text-rose-500">*</span>
                     </label>
                     <select 
                       value={periodId} 
                       onChange={e => setPeriodId(e.target.value)} 
                       className={`w-full h-10 border rounded-lg px-3 text-sm bg-white transition-all ${!periodId ? 'border-rose-200 bg-rose-50/20' : 'border-slate-200'}`}
                     >
                        <option value="">Periodo...</option>
                        {periods.map(p => <option key={p.id} value={p.id}>{p.name}</option>)}
                     </select>
                  </div>
               </div>
            </Card>
          </div>

          <Card className="shadow-lg overflow-hidden border-slate-100">
            <table className="w-full text-left border-collapse min-w-[600px]">
              <thead>
                <tr className="bg-slate-50 border-b text-[10px] uppercase font-bold text-slate-500">
                  <th className="p-3">Concepto / Artículo</th>
                  <th className="p-3 w-28 text-center">Cant.</th>
                  <th className="p-3 w-32 text-center">Trazabilidad</th>
                  <th className="p-3 w-32 text-center">Precio Unit.</th>
                  <th className="p-3 w-28 text-center">% IVA</th>
                  <th className="p-3 w-32 text-right">Total Línea</th>
                  <th className="p-3 w-12"></th>
                </tr>
              </thead>
              <tbody className="text-sm">
                {lines.map((l, idx) => {
                  const isLocked = !!l.baseId;
                  
                  return (
                    <tr key={idx} className={`border-b transition-colors ${isLocked ? 'bg-slate-50/80 cursor-not-allowed' : 'hover:bg-slate-50/50'}`}>
                      <td className="p-2 min-w-[250px]">
                         <div className="flex items-center gap-2">
                           {isLocked && <FileText size={14} className="text-slate-400" />}
                           <SearchableSelect 
                            options={items.map(i => ({ 
                              value: i.id, 
                              label: i.name, 
                              secondaryLabel: i.code 
                            }))}
                            value={l.itemId || ''}
                            onChange={(val) => !isLocked && updateLine(idx, 'itemId', val)}
                            disabled={isLocked}
                            placeholder="Buscar artículo..."
                           />
                         </div>
                      </td>
                      <td className="p-2">
                        <Input 
                          type="number" 
                          value={l.quantity} 
                          onChange={e => !isLocked && updateLine(idx, 'quantity', Number(e.target.value))} 
                          disabled={isLocked}
                          className={`h-8 text-center text-xs ${isLocked ? 'bg-slate-100/50 border-transparent text-slate-500 font-bold' : ''}`} 
                        />
                      </td>
                      <td className="p-2">
                         {(() => {
                           const item = items.find(i => i.id === l.itemId);
                           if (item && item.manageBy !== 'N') {
                             return (
                               <Button 
                                 variant="secondary" 
                                 size="sm" 
                                 type="button"
                                 onClick={() => setBatchEditingIdx(idx)}
                                 className={`w-full h-8 text-[10px] gap-2 border-dashed ${l.batchDetails?.length > 0 ? 'border-green-500 text-green-700 bg-green-50' : 'border-amber-500 text-amber-700 bg-amber-50'} ${isLocked ? 'opacity-80 pointer-events-none' : ''}`}
                               >
                                 <ClipboardList size={14} />
                                 {l.batchDetails?.length > 0 ? `${l.batchDetails.length} Detalle` : 'Asignar Lotes'}
                               </Button>
                             );
                           }
                           return <div className="text-center text-slate-300 text-[10px] uppercase font-bold italic">No gestionado</div>;
                         })()}
                      </td>
                      <td className="p-2">
                        <Input 
                          type="number" 
                          step="0.01" 
                          value={l.price} 
                          onChange={e => !isLocked && updateLine(idx, 'price', Number(e.target.value))} 
                          disabled={isLocked}
                          className={`h-8 text-right text-xs ${isLocked ? 'bg-slate-100/50 border-transparent text-slate-500' : ''}`} 
                        />
                      </td>
                      <td className="p-2">
                         <select 
                          value={l.taxGroupId || ''} 
                          onChange={e => !isLocked && updateLine(idx, 'taxGroupId', e.target.value)} 
                          disabled={isLocked}
                          className={`w-full h-8 border rounded-md text-xs bg-transparent ${isLocked ? 'text-slate-500' : ''}`}
                         >
                           <option value="">0%</option>
                           {taxGroups.map(t => <option key={t.id} value={t.id}>{t.rate}%</option>)}
                         </select>
                      </td>
                      <td className={`p-2 text-right font-bold ${isLocked ? 'text-slate-400' : 'text-slate-700'}`}>
                        {(() => {
                          const tax = taxGroups.find(t => t.id === l.taxGroupId);
                          const rate = tax ? Number(tax.rate) : 0;
                          const lineBase = Number(l.quantity) * Number(l.price);
                          return (lineBase + (lineBase * (rate / 100))).toFixed(2);
                        })()} €
                      </td>
                      <td className="p-2 text-center">
                        <div className="flex items-center justify-center gap-1">
                          {!isLocked && (
                            <button 
                              onClick={() => {
                                const newLine = { ...l, baseId: null, baseType: null, baseLine: null };
                                const newLines = [...lines];
                                newLines.splice(idx + 1, 0, newLine);
                                setLines(newLines);
                              }} 
                              className="text-slate-300 hover:text-blue-500 p-1"
                              title="Duplicar Línea"
                            >
                              <Copy size={14} />
                            </button>
                          )}
                          <button 
                            onClick={() => !isLocked && setLines(lines.filter((_, i) => i !== idx))} 
                            className={`text-slate-300 transition-colors ${isLocked ? 'cursor-not-allowed opacity-30' : 'hover:text-red-500'}`}
                            disabled={isLocked}
                          >
                            <Trash2 size={16} />
                          </button>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
              <div className="p-4 bg-slate-50 flex justify-between items-center border-t">
                {!lines.some(l => l.baseId) ? (
                  <div className="flex items-center gap-4">
                    <div className="flex items-center bg-slate-200/50 rounded-lg p-1 gap-1">
                       <button onClick={() => addLine()} className="h-7 min-w-[32px] rounded-md text-[10px] font-black bg-white hover:bg-blue-500 hover:text-white transition-all shadow-sm">+1</button>
                       <button onClick={() => {
                         const newLines = Array(5).fill(null).map(() => ({ itemId: '', quantity: 1, price: 0, taxGroupId: '', warehouseId: '' }));
                         setLines([...lines, ...newLines]);
                       }} className="h-7 min-w-[32px] rounded-md text-[10px] font-black bg-white hover:bg-blue-500 hover:text-white transition-all shadow-sm">+5</button>
                       <button onClick={() => {
                         const newLines = Array(10).fill(null).map(() => ({ itemId: '', quantity: 1, price: 0, taxGroupId: '', warehouseId: '' }));
                         setLines([...lines, ...newLines]);
                       }} className="h-7 min-w-[32px] rounded-md text-[10px] font-black bg-white hover:bg-blue-500 hover:text-white transition-all shadow-sm">+10</button>
                    </div>
                    <div className="h-6 w-[1px] bg-slate-200"></div>
                    <Button variant="secondary" size="sm" onClick={() => addLine()} className="h-8 border-2 bg-white hover:bg-blue-50 hover:border-blue-200 text-blue-600 font-bold border-slate-100">
                      <PlusSquare size={14} className="mr-2"/> Línea de Factura
                    </Button>
                  </div>
                ) : (
                  <div className="flex items-center gap-2 text-[10px] font-black uppercase text-slate-400 bg-slate-100 px-3 py-1.5 rounded-lg border border-slate-200">
                    <AlertCircle size={14} /> Modo Documento Base Activo: No se permiten líneas adicionales
                  </div>
                )}
                <div className="space-y-1 text-right min-w-[200px]">
                   <div className="flex justify-between text-xs text-slate-500 font-bold px-2">
                      <span>BASE IMPONIBLE:</span>
                      <span>{subtotal.toFixed(2)} €</span>
                   </div>
                   <div className="flex justify-between text-xs text-amber-600 font-bold px-2">
                      <span>CUOTA IVA:</span>
                      <span>{taxTotal.toFixed(2)} €</span>
                   </div>
                   <div className="flex justify-between text-lg font-black text-slate-800 border-t border-slate-200 mt-2 pt-1 px-2">
                      <span>TOTAL:</span>
                      <span>{total.toFixed(2)} €</span>
                   </div>
                </div>
              </div>
           </Card>

           {batchEditingIdx !== null && (
             <BatchSelectionModal 
               isOpen={true}
               onClose={() => setBatchEditingIdx(null)}
               targetQuantity={lines[batchEditingIdx].quantity}
               itemName={items.find(i => i.id === lines[batchEditingIdx].itemId)?.name || 'Artículo'}
               manageBy={items.find(i => i.id === lines[batchEditingIdx].itemId)?.manageBy || 'B'}
               initialDetails={lines[batchEditingIdx].batchDetails}
               onConfirm={(details) => updateLine(batchEditingIdx, 'batchDetails', details)}
             />
           )}
        </div>
      );
  }

  if (view === 'detail' && selectedInvoice) {
    return (
      <div className="p-8 max-w-7xl mx-auto space-y-6 animate-in slide-in-from-right duration-300">
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-4">
            <button onClick={() => setView('list')} className="p-2 hover:bg-white rounded-lg transition shadow-sm border">
              <ArrowLeft size={20} />
            </button>
            <h1 className="text-3xl font-black text-slate-900 tracking-tight">
              Factura {selectedInvoice.seriesPrefix}-{selectedInvoice.periodCode}-{String(selectedInvoice.docNum).padStart(6, '0')}
            </h1>
          </div>
          <div className="flex gap-3">
            {selectedInvoice.status === 'O' && (
              <Button variant="secondary" onClick={() => handleCancel(selectedInvoice.id)} className="flex items-center gap-2 border-rose-100 text-rose-600 hover:bg-rose-50">
                <Trash2 size={18} /> Cancelar y Reabrir Albaranes
              </Button>
            )}
          </div>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
          <Card className="p-6 md:col-span-2 space-y-6 shadow-xl border-slate-100">
            <div className="flex justify-between items-start border-b pb-3 mb-2">
              <div>
                <h4 className="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-1">PROVEEDOR / ACREEDOR</h4>
                <p className="text-xl font-black text-slate-900 leading-tight">
                  {partners.find(p => p.id === selectedInvoice.partnerId)?.name}
                </p>
              </div>
              <Badge variant="neutral" className="text-[10px] font-mono font-black border-slate-200 shadow-sm bg-slate-50">
                ID: {selectedInvoice.partnerId.substring(0,8)}
              </Badge>
            </div>
            
            <div className="flex items-center gap-3 p-3 bg-amber-50 border border-amber-100 rounded-xl">
               <FileText size={18} className="text-amber-600" />
               <p className="text-xs text-amber-800 font-medium">
                 Este documento es una factura contable firme y ha generado obligaciones de pago.
               </p>
            </div>
          </Card>

          <div className="space-y-6">
            <Card className="p-6 space-y-4 shadow-xl border-slate-100">
               <h4 className="text-[10px] font-black uppercase text-slate-400 tracking-widest border-b pb-2">CRONOGRAMA Y LOGÍSTICA</h4>
               <div className="space-y-3">
                  <div className="flex justify-between items-center text-sm">
                     <span className="text-slate-400 font-medium italic">Fec. Contabilización:</span>
                     <span className="font-bold text-slate-800">{new Date(selectedInvoice.date).toLocaleDateString()}</span>
                  </div>
                  <div className="flex justify-between items-center text-sm border-t pt-2">
                     <span className="text-slate-400 font-medium italic">Serie de Numeración:</span>
                     <span className="font-bold text-slate-700">{series.find(s => s.id === selectedInvoice.seriesId)?.name}</span>
                  </div>
               </div>
            </Card>

            <Card className="p-6 space-y-4 bg-slate-50 border-slate-200">
               <div>
                  <span className="text-[10px] font-black text-slate-400 uppercase">Estado Contable</span>
                  <div className="mt-1">
                    {selectedInvoice.status === 'O' ? <Badge variant="success">Asentado</Badge> : <Badge variant="error">Cancelado</Badge>}
                  </div>
               </div>
               {selectedInvoice.lines?.[0]?.baseId && (
                  <div className="pt-2 border-t border-slate-200">
                     <span className="text-[10px] font-black text-blue-400 uppercase">Trazabilidad</span>
                     <p className="text-[11px] font-bold text-blue-700 italic flex items-center gap-1 mt-1">
                        <FileText size={12} /> Proviene de Albaranes
                     </p>
                  </div>
               )}
            </Card>
          </div>
        </div>

        <Card className="shadow-lg overflow-hidden border-slate-100">
          <table className="w-full text-sm">
            <thead>
              <tr className="bg-slate-50 border-b text-[10px] uppercase font-bold text-slate-500">
                <th className="p-4 text-left">Artículo</th>
                <th className="p-4 w-32 text-center">Cantidad</th>
                <th className="p-4 w-32 text-right">Precio</th>
                <th className="p-4 w-32 text-right">Total</th>
              </tr>
            </thead>
            <tbody>
              {selectedInvoice.lines?.map((l: any, i: number) => (
                <tr key={i} className="border-b bg-white hover:bg-slate-50/50">
                  <td className="p-4">
                    <p className="font-bold text-slate-800">{items.find(it => it.id === l.itemId)?.name || 'Artículo'}</p>
                    <p className="text-[10px] text-slate-400 font-mono italic">{items.find(it => it.id === l.itemId)?.code}</p>
                    {l.batchDetails?.length > 0 && (
                      <div className="mt-2 flex flex-wrap gap-1.5">
                        {l.batchDetails.map((b: any, idx: number) => (
                          <Badge key={idx} variant="neutral" className="px-1.5 py-0.5 text-[9px] bg-indigo-50 text-indigo-700 border-indigo-100 font-bold uppercase">
                            {items.find(it => it.id === l.itemId)?.manageBy === 'S' ? 'S/N: ' : 'LOTE: '}
                            {b.batchNum} {items.find(it => it.id === l.itemId)?.manageBy === 'B' && `(${b.quantity})`}
                          </Badge>
                        ))}
                      </div>
                    )}
                  </td>
                  <td className="p-4 text-center font-bold text-slate-700">{Number(l.quantity).toFixed(2)}</td>
                  <td className="p-4 text-right font-medium text-slate-600">{Number(l.price).toFixed(2)} €</td>
                  <td className="p-4 text-right font-black text-slate-900">{(l.quantity * l.price).toFixed(2)} €</td>
                </tr>
              ))}
            </tbody>
          </table>
          <div className="p-6 bg-slate-900 text-white space-y-2 text-right border-t border-slate-800">
             <div className="flex justify-between items-center opacity-60 text-[10px] font-black uppercase tracking-widest">
                <span>Base Imponible</span>
                <span>{Number(selectedInvoice.subtotal || selectedInvoice.total || 0).toFixed(2)} €</span>
             </div>
             <div className="flex justify-between items-center text-amber-400 text-[10px] font-black uppercase tracking-widest">
                <span>Impuestos (IVA)</span>
                <span>{Number(selectedInvoice.taxTotal || 0).toFixed(2)} €</span>
             </div>
             <div className="flex justify-between items-center pt-3 mt-2 border-t border-slate-700/50">
               <span className="text-slate-400 font-black uppercase text-[10px] tracking-widest">Total Factura</span>
               <p className="text-3xl font-black text-white tracking-tighter">
                 {Number(selectedInvoice.total).toFixed(2)} <span className="text-sm font-light text-slate-400 ml-1">€</span>
               </p>
             </div>
          </div>
        </Card>
      </div>
    );
  }

  return (
    <div className="p-8 max-w-7xl mx-auto space-y-8 animate-in fade-in">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-3xl font-black text-slate-900 flex items-center gap-3 tracking-tight">
            <FileStack className="text-amber-600" size={32} />
            Facturas de Compra (Recibidas)
          </h1>
          <p className="text-slate-500 mt-1 font-medium">Registro para el libro de IVA y pagos a proveedores.</p>
        </div>
        <Button onClick={() => setView('create')} className="flex items-center gap-2 shadow-lg">
          <Plus size={18} /> Nueva Factura Directa
        </Button>
      </div>

      <Card className="overflow-hidden shadow-xl" noPadding>
        <FilterBar 
           searchTerm={searchTerm}
           onSearchChange={setSearchTerm}
           activeFilters={activeFilters}
           onFilterChange={setFilter}
           onClear={clearFilters}
           config={[
             { key: 'partnerId', label: 'Proveedor', type: 'select', options: partners.map(p => ({ label: p.name, value: p.id })) },
             { key: 'status', label: 'Estado', type: 'select', options: [
               { label: 'Asentado', value: 'O' },
               { label: 'Cancelado', value: 'X' }
             ]},
             { key: 'date', label: 'Fecha', type: 'date' }
           ]}
           searchPlaceholder="Buscar por factura o albarán..."
        />
        <Table columns={listColumns} data={filteredData} isLoading={loading} />
      </Card>
    </div>
  );
};
