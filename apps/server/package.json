{
  "name": "@openfactu/server",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --watch ../../node_modules/@openfactu/pdf/dist,../../node_modules/@openfactu/common/dist src/server.ts",
    "build": "tsc --noEmit && tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/core/tenant/migrations dist/seed-data && cp src/core/tenant/migrations/*.sql dist/core/tenant/migrations/ && cp src/seed-data/* dist/seed-data/",
    "start": "node dist/server.js",
    "sync": "ts-node src/scripts/sync-all-tenants.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:public": "ts-node src/scripts/push-public.ts"
  },
  "dependencies": {
    "@openfactu/common": "^0.0.2",
    "@openfactu/pdf": "^0.1.1",
    "@types/adm-zip": "^0.5.8",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^6.4.23",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "bwip-js": "^4.9.2",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
